{
  "appId": "com.swaya.app",
  "productName": "SWAYA",
  "icon": "public/favicon/icon.ico",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "build/**/*",
    "main.js",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "backend",
      "to": "backend",
      "filter": ["**/*"]
    },
    {
      "from": "bin",
      "to": "bin",
      "filter": ["win/**/*"]
    }
  ],
  "win": {
    "target": "dir",
    "icon": "public/favicon/icon.ico"
  },
  "linux": {
    "target": [
      "AppImage"
    ],
    "icon": "public/favicon"
  }
}
